          </Button>
        </Link>
        <div className="flex items-center gap-2">
          <span className="text-3xl">⚽</span>
          <h1 className="text-3xl font-bold">Apuestas de Fútbol</h1>
          <Badge className="bg-green-500 text-white">
            <Zap className="h-3 w-3 mr-1" />
            {filteredPartidos.length} partidos disponibles
          </Badge>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-6 gap-6">
        {/* Sidebar */}
        <div className="lg:col-span-2 space-y-6">
          {/* Países */}
          <Card className="border-2">
            <CardContent className="p-4">
              <h2 className="font-bold mb-4 flex items-center gap-2">
                <Globe className="h-5 w-5 text-primary" />
                Países
              </h2>
              <div className="space-y-1 max-h-64 overflow-y-auto">
                {paises.map((pais) => (
                  <Button
                    key={pais.id}
                    variant={selectedCountry === pais.id ? "default" : "ghost"}
                    className="w-full justify-between h-auto py-2"
                    onClick={() => setSelectedCountry(pais.id)}
                  >
                    <div className="flex items-center gap-2">
                      <span className="text-sm">{pais.flag}</span>
                      <span className="text-xs">{pais.name}</span>
                    </div>
                    <Badge variant="secondary" className="text-xs">
                      {pais.count}
                    </Badge>
                  </Button>
                ))}
              </div>
            </CardContent>
          </Card>

          {/* Ligas */}
          <Card className="border-2">
            <CardContent className="p-4">
              <h2 className="font-bold mb-4 flex items-center gap-2">
                <Trophy className="h-5 w-5 text-primary" />
                Competiciones
              </h2>
              <div className="space-y-1 max-h-80 overflow-y-auto">
                {ligas.map((liga) => (
                  <Button
                    key={liga.id}
                    variant={selectedLeague === liga.name ? "default" : "ghost"}
                    className="w-full justify-between h-auto py-2"
                    onClick={() => setSelectedLeague(liga.name)}
                  >
                    <div className="flex items-center gap-2">
                      <span className="text-xs">{liga.flag}</span>
                      <span className="text-xs">{liga.name}</span>
                      {liga.tier === 1 && <Star className="h-3 w-3 text-yellow-500" />}
                    </div>
                    <Badge variant="secondary" className="text-xs">
                      {liga.count}
                    </Badge>
                  </Button>
                ))}
              </div>
            </CardContent>
          </Card>

          {/* Filtros Rápidos */}
          <Card className="border-2">
            <CardContent className="p-4">
              <h2 className="font-bold mb-4 flex items-center gap-2">
                <Target className="h-5 w-5 text-primary" />
                Filtros Rápidos
              </h2>
              <div className="space-y-2">
                <Button className="w-full justify-start" size="sm">
                  <Clock className="h-4 w-4 mr-2" />
                  Partidos de Hoy
                </Button>
                <Button variant="outline" className="w-full justify-start" size="sm">
                  <Star className="h-4 w-4 mr-2" />
                  Destacados
                </Button>
                <Button variant="outline" className="w-full justify-start" size="sm">
                  <Play className="h-4 w-4 mr-2" />
                  En Vivo
                </Button>
                <Button variant="outline" className="w-full justify-start" size="sm">
                  <TrendingUp className="h-4 w-4 mr-2" />
                  Más Populares
                </Button>
              </div>
            </CardContent>
          </Card>
        </div>

        {/* Main Content */}
        <div className="lg:col-span-4 space-y-6">
          <div className="flex items-center gap-4">
            <div className="relative flex-1">
              <Search className="absolute left-2.5 top-2.5 h-4 w-4 text-muted-foreground" />
              <Input
                type="search"
                placeholder="Buscar equipos, ligas o competiciones..."
                className="pl-8"
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
              />
            </div>
            <Button variant="outline" size="icon" className="shrink-0">
              <Filter className="h-4 w-4" />
            </Button>
          </div>

          <Tabs defaultValue="todos">
            <TabsList className="grid w-full grid-cols-4">
              <TabsTrigger value="todos">Todos</TabsTrigger>
              <TabsTrigger value="hoy">Hoy</TabsTrigger>
              <TabsTrigger value="directo">En Directo</TabsTrigger>
              <TabsTrigger value="destacados">Destacados</TabsTrigger>
            </TabsList>

            <TabsContent value="todos" className="mt-6">
              <div className="space-y-4">
                {filteredPartidos.map((partido) => (
                  <Card
                    key={partido.id}
                    className="overflow-hidden border-2 hover:border-primary/30 transition-all duration-300 hover:shadow-xl bg-gradient-to-r from-card via-card to-card/95"
                  >
                    <CardContent className="p-0">
                      {/* Header */}
                      <div className="p-4 border-b bg-gradient-to-r from-muted/30 to-muted/10">
                        <div className="flex items-center justify-between mb-3">
                          <div className="flex items-center gap-3">
                            <Badge
                              variant="outline"
                              className="bg-primary/10 text-primary font-medium border-primary/20"
                            >
                              {partido.liga}
                            </Badge>
                            {partido.popularidad > 85 && (
                              <Badge className="bg-yellow-500 text-black">
                                <Star className="h-3 w-3 mr-1" />
                                Popular
                              </Badge>
                            )}
                            {partido.live && (
                              <Badge variant="destructive" className="animate-pulse">
                                <span className="h-2 w-2 bg-white rounded-full mr-1"></span>
                                EN VIVO
                              </Badge>
                            )}
                          </div>
                          <div className="flex items-center text-sm">
                            {partido.live ? (
                              <div className="text-red-600 font-bold">{partido.tiempo}</div>
                            ) : (
                              <div className="flex items-center text-muted-foreground">
                                <Clock className="mr-1 h-4 w-4" />
                                {partido.fecha}
                              </div>
                            )}
                          </div>
                        </div>

                        {/* Teams with logos */}
                        <div className="grid grid-cols-5 items-center gap-4">
                          <div className="col-span-2 flex items-center gap-3">
                            <Image
                              src={partido.logoLocal || "/placeholder.svg"}
                              alt={partido.equipoLocal}
                              width={40}
                              height={40}
                              className="rounded-full border-2 border-muted"
                            />
                            <div>
                              <div className="font-bold text-lg">{partido.equipoLocal}</div>
                              <div className="text-xs text-muted-foreground">Local</div>
                            </div>
                          </div>

                          <div className="text-center">
                            {partido.live ? (
                              <div className="text-3xl font-bold text-primary">{partido.resultado}</div>
                            ) : (
                              <div className="text-lg font-medium text-muted-foreground">VS</div>
                            )}
                          </div>

                          <div className="col-span-2 flex items-center gap-3 justify-end">
                            <div className="text-right">
                              <div className="font-bold text-lg">{partido.equipoVisitante}</div>
                              <div className="text-xs text-muted-foreground">Visitante</div>
                            </div>
                            <Image
                              src={partido.logoVisitante || "/placeholder.svg"}
                              alt={partido.equipoVisitante}
                              width={40}
                              height={40}
                              className="rounded-full border-2 border-muted"
                            />
                          </div>
                        </div>

                        {/* Match info */}
                        <div className="flex items-center justify-center mt-3 text-xs text-muted-foreground">
                          <span>📍 {partido.estadio}</span>
                        </div>
                      </div>

                      {/* Betting Markets */}
                      <div className="p-4 space-y-4">
                        {/* 1X2 Market */}
                        <div>
                          <h4 className="text-sm font-semibold mb-3 text-muted-foreground">Resultado Final</h4>
                          <div className="grid grid-cols-3 gap-3">
                            <Button
                              variant={isBetSelected(partido.id, "home", "1x2") ? "default" : "outline"}
                              className={`h-20 flex flex-col justify-center transition-all duration-200 ${isBetSelected(partido.id, "home", "1x2")
                                ? "bg-primary text-primary-foreground shadow-lg scale-105 border-primary"
                                : "hover:bg-primary/10 hover:border-primary/50 hover:scale-105"
                                }`}
                              onClick={() => handleBetSelection(partido, "home", partido.cuotaLocal, "1x2")}
                            >
                              <span className="text-xs font-medium mb-2">1 - Local</span>
                              <span className="text-xl font-bold">{partido.cuotaLocal}</span>
                            </Button>
                            {partido.cuotaEmpate && (
                              <Button
                                variant={isBetSelected(partido.id, "draw", "1x2") ? "default" : "outline"}
                                className={`h-20 flex flex-col justify-center transition-all duration-200 ${isBetSelected(partido.id, "draw", "1x2")
                                  ? "bg-primary text-primary-foreground shadow-lg scale-105 border-primary"
                                  : "hover:bg-primary/10 hover:border-primary/50 hover:scale-105"
                                  }`}
                                onClick={() => handleBetSelection(partido, "draw", partido.cuotaEmpate, "1x2")}
                              >
                                <span className="text-xs font-medium mb-2">X - Empate</span>
                                <span className="text-xl font-bold">{partido.cuotaEmpate}</span>
                              </Button>
                            )}
                            <Button
                              variant={isBetSelected(partido.id, "away", "1x2") ? "default" : "outline"}
                              className={`h-20 flex flex-col justify-center transition-all duration-200 ${isBetSelected(partido.id, "away", "1x2")
                                ? "bg-primary text-primary-foreground shadow-lg scale-105 border-primary"
                                : "hover:bg-primary/10 hover:border-primary/50 hover:scale-105"
                                }`}
                              onClick={() => handleBetSelection(partido, "away", partido.cuotaVisitante, "1x2")}
                            >
                              <span className="text-xs font-medium mb-2">2 - Visitante</span>
                              <span className="text-xl font-bold">{partido.cuotaVisitante}</span>
                            </Button>
                          </div>
                        </div>

                        {/* Over/Under Market */}
                        {partido.overUnder && (
                          <div>
                            <h4 className="text-sm font-semibold mb-3 text-muted-foreground">
                              Total Goles {partido.overUnder.line}
                            </h4>
                            <div className="grid grid-cols-2 gap-3">
                              <Button
                                variant={isBetSelected(partido.id, "over", "overunder") ? "default" : "outline"}
                                className={`h-16 flex flex-col justify-center transition-all duration-200 ${isBetSelected(partido.id, "over", "overunder")
                                  ? "bg-green-600 text-white shadow-lg border-green-600"
                                  : "hover:bg-green-50 hover:border-green-300 dark:hover:bg-green-950/20"
                                  }`}
                                onClick={() => handleBetSelection(partido, "over", partido.overUnder.over, "overunder")}
                              >
                                <span className="text-xs font-medium mb-1">Más de {partido.overUnder.line}</span>
                                <span className="text-lg font-bold">{partido.overUnder.over}</span>
                              </Button>
                              <Button
                                variant={isBetSelected(partido.id, "under", "overunder") ? "default" : "outline"}
                                className={`h-16 flex flex-col justify-center transition-all duration-200 ${isBetSelected(partido.id, "under", "overunder")
                                  ? "bg-red-600 text-white shadow-lg border-red-600"
                                  : "hover:bg-red-50 hover:border-red-300 dark:hover:bg-red-950/20"
                                  }`}
                                onClick={() =>
                                  handleBetSelection(partido, "under", partido.overUnder.under, "overunder")
                                }
                              >
                                <span className="text-xs font-medium mb-1">Menos de {partido.overUnder.line}</span>
                                <span className="text-lg font-bold">{partido.overUnder.under}</span>
                              </Button>
                            </div>
                          </div>
                        )}

                        {/* More Markets Button */}
                        <Link href={`/apuestas/partido/${partido.id}`}>
                          <Button
                            variant="outline"
                            className="w-full h-14 bg-gradient-to-r from-muted/50 to-muted/30 hover:from-primary/10 hover:to-primary/5 border-dashed border-2 hover:border-primary/30 transition-all duration-300"
                          >
                            <div className="flex items-center justify-center gap-2">
                              <Users className="h-5 w-5" />
                              <span className="font-semibold">Ver todos los {partido.mercados} mercados</span>
                              <ChevronRight className="h-4 w-4" />
                              {partido.live && <Play className="h-4 w-4 text-red-500 animate-pulse" />}
                            </div>
                          </Button>
                        </Link>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </TabsContent>

            {/* Other tabs with filtered content */}
            <TabsContent value="hoy" className="mt-6">
              <div className="space-y-4">
                {filteredPartidos
                  .filter((partido) => partido.fecha.includes("Hoy"))
                  .map((partido) => (
                    <Card key={partido.id} className="p-6 text-center">
                      <h3 className="text-lg font-semibold mb-2">
                        {partido.equipoLocal} vs {partido.equipoVisitante}
                      </h3>
                      <p className="text-muted-foreground">
                        {partido.liga} - {partido.fecha}
                      </p>
                    </Card>
                  ))}
              </div>
            </TabsContent>

            <TabsContent value="directo" className="mt-6">
              <div className="space-y-4">
                {filteredPartidos
                  .filter((partido) => partido.live)
                  .map((partido) => (
                    <Card
                      key={partido.id}
                      className="p-6 text-center border-2 border-red-500/30 bg-red-50/50 dark:bg-red-950/20"
                    >
                      <Badge variant="destructive" className="mb-4">
                        EN VIVO
                      </Badge>
                      <h3 className="text-lg font-semibold mb-2">
                        {partido.equipoLocal} vs {partido.equipoVisitante}
                      </h3>
                      <p className="text-muted-foreground">
                        {partido.liga} - {partido.tiempo}
                      </p>
                      {partido.resultado && (
                        <div className="text-2xl font-bold text-red-600 mt-2">{partido.resultado}</div>
                      )}
                    </Card>
                  ))}
              </div>
            </TabsContent>

            <TabsContent value="destacados" className="mt-6">
              <div className="space-y-4">
                {filteredPartidos
                  .filter((partido) => partido.destacado)
                  .map((partido) => (
                    <Card
                      key={partido.id}
                      className="p-6 text-center border-2 border-yellow-500/30 bg-yellow-50/50 dark:bg-yellow-950/20"
                    >
                      <Badge className="bg-yellow-500 text-black mb-4">
                        <Star className="h-3 w-3 mr-1" />
                        DESTACADO
                      </Badge>
                      <h3 className="text-lg font-semibold mb-2">
                        {partido.equipoLocal} vs {partido.equipoVisitante}
                      </h3>
                      <p className="text-muted-foreground">
                        {partido.liga} - {partido.fecha}
                      </p>
                    </Card>
                  ))}
              </div>
            </TabsContent>
          </Tabs>
        </div>
      </div>

      {/* Bet Slip */}
      <BetSlip open={showBetSlip} onOpenChange={setShowBetSlip} bets={selectedBets} onRemoveBet={removeBet} />
    </div>
  )
}